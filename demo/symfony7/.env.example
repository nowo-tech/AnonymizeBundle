# In all environments, the following files are loaded if they exist (later files override earlier ones):
#   .env, .env.local, .env.$APP_ENV, .env.$APP_ENV.local
# Real environment variables win over .env files.
# Do not commit secrets. https://symfony.com/doc/current/configuration/secrets.html

# APP_ENV: Symfony environment (dev/test/prod). In this demo it is usually `dev`.
APP_ENV=dev

# APP_DEBUG: Enable/disable detailed debug output (1 in dev).
APP_DEBUG=1

# APP_SECRET: Secret for signing/tokens. Use a local-only value in development.
APP_SECRET=demo-secret-change-me

# PORT: Host port mapped to the FrankenPHP (Caddy) HTTP service (see docker-compose `php` service).
PORT=8000

# DEFAULT_URI: Base URL for CLI URL generation and docs; must match PORT above.
DEFAULT_URI=http://localhost:8000

# TRUSTED_PROXIES: Trusted proxies when behind Caddy/Traefik (optional).
TRUSTED_PROXIES=127.0.0.1

# DATABASE_URL: MySQL (default Doctrine connection) — use Docker service hostname `mysql`, not localhost.
DATABASE_URL=mysql://demo_user:password@mysql:3306/anonymize_demo?serverVersion=8.0&charset=utf8mb4

# DATABASE_URL_POSTGRES: PostgreSQL (second entity manager) — hostname `postgres`.
DATABASE_URL_POSTGRES=postgresql://demo_user:password@postgres:5432/anonymize_demo?serverVersion=16&charset=utf8

# MONGODB_URL: MongoDB demo database — hostname `mongodb` on the Docker network.
MONGODB_URL=mongodb://demo_user:password@mongodb:27017/anonymize_demo?authSource=admin

# MySQL container credentials (used by docker-compose for the `mysql` service).
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=anonymize_demo
MYSQL_USER=demo_user
MYSQL_PASSWORD=password

# PostgreSQL container credentials (used by docker-compose for the `postgres` service).
POSTGRES_USER=demo_user
POSTGRES_PASSWORD=password
POSTGRES_DB=anonymize_demo

# MongoDB container credentials.
MONGODB_USER=demo_user
MONGODB_PASSWORD=password
MONGODB_DATABASE=anonymize_demo

# pgAdmin (optional UI).
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# mongo-express (optional UI).
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin
