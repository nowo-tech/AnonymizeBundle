{
	skip_install_trust
	# Timeout hierarchy (REQ-RUNTIME-001): export.timeout (180s) < PHP (240s) < Caddy write (250s).
	servers {
		timeouts {
			read_body 60s
			read_header 30s
			write 250s
			idle 5m
		}
	}
	frankenphp {
		php_ini max_execution_time 240
		php_ini max_input_time 240
		max_wait_time 30s
	}
}

:80 {
	root * /app/public
	encode zstd br gzip
	php_server {
		worker /app/public/index.php
	}
}
