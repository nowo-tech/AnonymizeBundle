# PHPStan configuration for Anonymize Bundle
# Compatible with PHP 8.2+ and Symfony 6.x / 7.x / 8.x

includes:
    - phpstan-baseline.neon
    - vendor/nowo-tech/phpstan-frankenphp/ruleset-classic.neon
    - vendor/nowo-tech/phpstan-frankenphp/ruleset-worker.neon

parameters:
    level: 8
    treatPhpDocTypesAsCertain: true
    paths:
        - src
        - tests
    excludePaths:
        - demo/*
    # Tests keep runtime type assertions (assertIsString, assertNull, …). With
    # treatPhpDocTypesAsCertain they become tautologies for PHPStan; ignore only
    # in tests so src still benefits from certain PHPDoc types.
    ignoreErrors:
        -
            identifier: method.alreadyNarrowedType
            path: tests/*
        -
            identifier: function.alreadyNarrowedType
            path: tests/*
        -
            identifier: staticMethod.alreadyNarrowedType
            path: tests/*
